{
    "name": "standard-assets-bundle",
    "displayName": "Standard Assets Bundle",
    "version": "2.1.0",
    "private": true,
    "description": "Teraslice standard processor asset bundle",
    "homepage": "https://github.com/terascope/standard-assets",
    "bugs": {
        "url": "https://github.com/terascope/standard-assets/issues"
    },
    "type": "module",
    "scripts": {
        "asset:build": "pnpm install && pnpm run build",
        "asset:post-build": "./scripts/copy-links.sh",
        "build": "tsc --build",
        "build:watch": "tsc --build --watch",
        "bump": "ts-scripts bump",
        "bump-asset": "ts-scripts bump-asset",
        "docker:limit": "./scripts/docker-limit-check.sh",
        "docker:listImages": "ts-scripts images list",
        "docker:saveImages": "ts-scripts images save",
        "docs": "ts-scripts docs",
        "lint": "eslint",
        "lint:fix": "pnpm lint --fix",
        "publish:changed": "./scripts/publish.sh",
        "setup": "pnpm install && pnpm build --force",
        "test": "ts-scripts test asset -- --testPathIgnorePatterns=test/e2e",
        "test:all": "ts-scripts test -- --testPathIgnorePatterns=test/e2e",
        "test:debug": "ts-scripts test --debug asset -- --testPathIgnorePatterns=test/e2e",
        "test:e2e": "earl assets build --overwrite && ASSET_ZIP_PATH=$(./scripts/asset-zip-path.sh) TEST_TERASLICE=true TEST_OPENSEARCH=true ts-scripts test -- --testPathPatterns=test/e2e",
        "test:encrypted": "echo 'No encrypted tests for standard assets'",
        "test:watch": "ts-scripts test --watch asset --"
    },
    "devDependencies": {
        "@jest/globals": "^30.3.0",
        "@terascope/core-utils": "~2.5.1",
        "@terascope/eslint-config": "~1.1.30",
        "@terascope/job-components": "~2.6.0",
        "@terascope/opensearch-client": "~2.5.1",
        "@terascope/scripts": "~2.6.1",
        "@terascope/standard-asset-apis": "workspace:~",
        "@terascope/types": "~2.5.0",
        "@types/fs-extra": "~11.0.4",
        "@types/jest": "~30.0.0",
        "@types/json2csv": "~5.0.7",
        "@types/node": "~24.10.15",
        "@types/node-gzip": "~1.1.3",
        "@types/semver": "~7.7.1",
        "@types/timsort": "~0.3.3",
        "eslint": "~9.39.4",
        "execa": "~9.6.1",
        "fs-extra": "~11.3.4",
        "jest": "~30.3.0",
        "jest-extended": "~7.0.0",
        "node-notifier": "~10.0.1",
        "semver": "~7.7.4",
        "teraslice-client-js": "~2.5.1",
        "teraslice-test-harness": "~2.7.0",
        "ts-jest": "~29.4.9",
        "tslib": "~2.8.1",
        "typescript": "~5.9.3"
    },
    "packageManager": "pnpm@10.25.0",
    "engines": {
        "node": ">=22.21.1",
        "pnpm": ">=10.25.0"
    },
    "documentation": "https://terascope.github.io/standard-assets",
    "terascope": {
        "root": true,
        "testSuite": "unit",
        "tests": {
            "suites": {
                "unit": []
            }
        }
    }
}
